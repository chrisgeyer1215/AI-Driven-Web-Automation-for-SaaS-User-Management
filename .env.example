# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Browser Configuration
HEADLESS_MODE=true
BROWSER_TYPE=chromium

# SaaS Application Credentials (for testing)
DROPBOX_TEST_EMAIL=your_test_email@example.com
DROPBOX_TEST_PASSWORD=your_test_password
DROPBOX_TEST_MFA_SECRET=your_mfa_secret_key

NOTION_TEST_EMAIL=your_test_email@example.com
NOTION_TEST_PASSWORD=your_test_password

# Rate Limiting Configuration
DEFAULT_RATE_LIMIT_MS=2000
MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=automation.log

# Security Configuration
ENCRYPT_CREDENTIALS=true
SESSION_TIMEOUT_MINUTES=30